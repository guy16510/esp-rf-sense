{
  "name": "esp32-rf-sense-lab",
  "version": "0.1.0",
  "private": true,
  "description": "Research harness for device-free RF activity sensing with an ESP32-S3 and Node.js realtime dashboard.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22 <23"
  },
  "workspaces": [
    "tools/collector",
    "tools/ota-server",
    "tools/cli",
    "tools/experiments"
  ],
  "scripts": {
    "rf": "node tools/rf.mjs",
    "build": "tsc --build tools/collector tools/ota-server tools/cli tools/experiments apps/dashboard",
    "clean": "tsc --build --clean tools/collector tools/ota-server tools/cli tools/experiments apps/dashboard",
    "typecheck": "tsc --build tools/collector tools/ota-server tools/cli tools/experiments apps/dashboard",
    "lint": "eslint \"tools/**/src/**/*.ts\" \"apps/**/src/**/*.ts\"",
    "format:check": "prettier --check \"tools/**/src/**/*.ts\" \"apps/**/src/**/*.ts\" \"*.json\"",
    "format": "prettier --write \"tools/**/src/**/*.ts\" \"apps/**/src/**/*.ts\" \"*.json\"",
    "test": "vitest run",
    "collector:start": "tsx tools/collector/src/cli.ts",
    "dashboard": "tsx apps/dashboard/src/four-node-cli.ts",
    "dashboard:start": "tsx apps/dashboard/src/four-node-cli.ts",
    "dashboard:device": "tsx apps/dashboard/src/cli.ts --device http://rf-sense-a1b2.local",
    "dashboard:phone": "tsx apps/dashboard/src/cli.ts --http-host 0.0.0.0 --device http://rf-sense-a1b2.local",
    "firmware:bundle": "cd firmware && idf.py set-target esp32s3 && idf.py build && python tools/size_check.py --app build/rf-sense.bin && python tools/build_bootstrap_bundle.py --build-dir build --out ../dist/bootstrap",
    "firmware:flash:configured": "node tools/flash-configured.mjs",
    "flash": "npm run firmware:flash:configured",
    "flash:fresh": "npm run firmware:bundle && npm run flash",
    "experiment:start": "tsx tools/experiments/src/cli.ts start",
    "experiment:stop": "tsx tools/experiments/src/cli.ts stop",
    "experiment:status": "tsx tools/experiments/src/cli.ts status",
    "export:csv": "tsx tools/collector/src/export-csv.ts",
    "ota-server:start": "tsx tools/ota-server/src/cli.ts",
    "device:discover": "tsx tools/cli/src/discover.ts",
    "device:ota:check": "tsx tools/cli/src/ota.ts check",
    "device:ota:apply": "tsx tools/cli/src/ota.ts apply",
    "device:status": "tsx tools/cli/src/status.ts"
  },
  "devDependencies": {
    "@types/node": "22.19.21",
    "@typescript-eslint/eslint-plugin": "8.20.0",
    "@typescript-eslint/parser": "8.20.0",
    "eslint": "9.39.4",
    "prettier": "3.4.2",
    "tsx": "4.22.4",
    "typescript": "5.7.3",
    "vitest": "4.1.9"
  }
}
